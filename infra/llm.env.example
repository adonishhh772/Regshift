# RegShift LLM gateway — production model routing
# Copy to backend/.env or inject via Docker/K8s secrets.

LLM_GATEWAY_ENABLED=true
LLM_FALLBACK_TO_RULES=true
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2

# Route format: provider:model chains (comma-separated fallbacks)
# Providers: openai | azure_openai | anthropic | gateway
LLM_ROUTE_CLASSIFY=openai:gpt-4o-mini,azure_openai:gpt-4o-mini,gateway:gpt-4o-mini
LLM_ROUTE_CONTRACT=openai:gpt-4o,gateway:gpt-4o,azure_openai:gpt-4o
LLM_ROUTE_POLICY_INGEST=openai:gpt-4o,gateway:gpt-4o,azure_openai:gpt-4o

# OpenAI (direct)
OPENAI_API_KEY=
OPENAI_API_BASE=

# OpenAI-compatible gateway (LiteLLM, Portkey, Azure AI Foundry proxy, etc.)
LLM_GATEWAY_URL=
LLM_GATEWAY_API_KEY=

# Azure OpenAI (deployment name as model in routes)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Anthropic
ANTHROPIC_API_KEY=
