# Langfuse self-hosted init (required for auto-provisioned project keys)
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=regshift-langfuse-nextauth-secret-min-32-chars
SALT=regshift-langfuse-salt-secret-minimum-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

POSTGRES_USER=postgres
POSTGRES_PASSWORD=regshift-langfuse-postgres-password-min-32-chars
POSTGRES_DB=langfuse
DATABASE_URL=postgresql://postgres:regshift-langfuse-postgres-password-min-32-chars@langfuse-postgres:5432/langfuse

CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=regshift-langfuse-clickhouse-password-min-32-chars
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000
CLICKHOUSE_URL=http://langfuse-clickhouse:8123

REDIS_AUTH=regshift-langfuse-redis-password-minimum-32-chars
REDIS_HOST=langfuse-redis

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=regshift-langfuse-minio-password-minimum-32-chars

LANGFUSE_INIT_ORG_ID=regshift-org
LANGFUSE_INIT_ORG_NAME=RegShift
LANGFUSE_INIT_PROJECT_ID=regshift-project
LANGFUSE_INIT_PROJECT_NAME=RegShift
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-regshift-dev-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-regshift-dev-secret-key-min-32-chars
LANGFUSE_INIT_USER_EMAIL=admin@regshift.local
LANGFUSE_INIT_USER_NAME=RegShift Admin
LANGFUSE_INIT_USER_PASSWORD=regshift-langfuse-admin-password-min-32-chars

# Backend tracing (copy public/secret keys to backend env)
LANGFUSE_PUBLIC_KEY=pk-lf-regshift-dev-public-key
LANGFUSE_SECRET_KEY=sk-lf-regshift-dev-secret-key-min-32-chars
LANGFUSE_HOST=http://langfuse-web:3000
